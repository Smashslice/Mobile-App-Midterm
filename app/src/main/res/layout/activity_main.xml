<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/main"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to Campus Coffee! \nPlace your order below"
        android:padding="5dp"
        android:layout_marginHorizontal="5dp"
        android:textAlignment="center"
        />

    <EditText
        android:id="@+id/ordName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="@string/name_hint"
        android:layout_marginHorizontal="5dp"
        android:padding="5dp" />

    <Spinner
        android:id="@+id/coffee_type_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginHorizontal="5dp"
        android:layout_margin="5dp"
        />

    <Spinner
        android:id="@+id/coffee_size_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginHorizontal="5dp"
        android:layout_margin="5dp"
        />

    <EditText
        android:id="@+id/ordBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/bal_hint"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp"
        android:padding="5dp"
        android:layout_marginHorizontal="5dp"
        android:layout_margin="5dp"
        />

    <Button
        android:id="@+id/btnPlace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Place Order"
        android:padding="5dp"
        android:layout_marginHorizontal="5dp"
        android:layout_margin="5dp"
        />

</LinearLayout>